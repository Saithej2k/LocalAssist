<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDisplayName</key>
	<string>local assist</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>com.saithej.localassist</string>
	<key>CFBundleName</key>
	<string>local assist</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.saithej.localassist</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>localassist</string>
			</array>
		</dict>
	</array>
	<key>LSApplicationCategoryType</key>
	<string>public.app-category.productivity</string>
	<key>NSCameraUsageDescription</key>
	<string>LocalAssist scans whiteboards, receipts, and handwriting with the camera. Text extraction happens entirely on device.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>LocalAssist records voice notes only when you tap the microphone, then turns the transcript into a private local brief.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>LocalAssist uses speech recognition to transcribe voice notes into tasks and action drafts.</string>
	<key>NSRemindersFullAccessUsageDescription</key>
	<string>LocalAssist creates reminders you explicitly confirm from your summarized notes. Nothing is written without your confirmation.</string>
	<key>NSCalendarsFullAccessUsageDescription</key>
	<string>LocalAssist checks your free time to ground scheduling suggestions and creates calendar holds you explicitly confirm.</string>
	<key>NSContactsUsageDescription</key>
	<string>LocalAssist matches names in your notes to your contacts so drafts reference real people. Lookups happen entirely on device.</string>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
	</dict>
	<key>UILaunchScreen</key>
	<dict/>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
</dict>
</plist>
